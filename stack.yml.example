lab:
  name: "Example Institute"
  contact: "bio@example.org"

auth:
  provider: ls-login
  ls_login:
    client_id: "replace-me"
    client_secret: "replace-me"
    redirect_uri: "https://beacon.lab.example.org/oauth2/callback"
  # For local Keycloak instead of LS Login:
  # provider: keycloak
  # ls_login:
  #   client_id: "replace-me"
  #   client_secret: "replace-me"
  #   redirect_uri: "https://beacon.lab.example.org/oauth2/callback"
  # keycloak:
  #   issuer_url: "http://localhost:8080/realms/master"

services:
  beacon:
    enabled: true
    access_level: registered
    dataset_name: "Example cohort"
  wes:
    enabled: false
    engine: nextflow
  tes:
    enabled: false
    backend: slurm
    slurm:
      partition: short
  drs:
    enabled: false

deploy:
  target: compose
  host: "beacon.lab.example.org"
  tls: true
